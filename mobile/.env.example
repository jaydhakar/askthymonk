# Base URL of the FastAPI backend, as reachable FROM YOUR DEVICE.
#
# - Deployed backend (Render): the public URL, e.g.
#     EXPO_PUBLIC_API_URL=https://askthymonk-backend.onrender.com
# - iOS simulator / web on the same machine: http://localhost:8000
# - A physical phone against a LOCAL backend (dev client): your computer's LAN IP,
#     EXPO_PUBLIC_API_URL=http://192.168.1.20:8000
#   (find it on Windows with `ipconfig` -> IPv4 Address). Phone and PC must be
#   on the same Wi-Fi, and the backend must listen on your LAN (--host 0.0.0.0).
#
# EXPO_PUBLIC_ vars are inlined at BUNDLE time — change this and re-bundle (Metro
# restart for dev-client; rebuild for a standalone preview/production APK).
# For EAS cloud builds, .env is NOT uploaded — set these as the build profile's
# `env` (non-secret) or as EAS environment variables (secret). See eas.json.
EXPO_PUBLIC_API_URL=http://localhost:8000

# Shared secret sent as the X-API-Key header — MUST exactly match the backend's
# API_SHARED_SECRET. Required whenever the backend has the gate enabled (e.g. the
# deployed Render URL); leave empty only if the backend's API_SHARED_SECRET is
# also empty (local dev). A mismatch/absence yields 401 on every /api/wisdom call.
EXPO_PUBLIC_API_KEY=
