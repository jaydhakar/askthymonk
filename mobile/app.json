{
  "expo": {
    "name": "Ask Thy Monk",
    "slug": "askthymonk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "askthymonk",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jaydhakar.askthymonk",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Ask Thy Monk uses the microphone so you can ask your questions by voice.",
        "NSSpeechRecognitionUsageDescription": "Ask Thy Monk uses speech recognition to turn your spoken question into text."
      }
    },
    "android": {
      "package": "com.jaydhakar.askthymonk",
      "adaptiveIcon": {
        "backgroundColor": "#F3ECE2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Ask Thy Monk uses the microphone so you can ask your questions by voice.",
          "speechRecognitionPermission": "Ask Thy Monk uses speech recognition to turn your spoken question into text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F3ECE2"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "9b462fd8-c066-44dc-9e4e-57ad750b3a41"
      }
    },
    "owner": "jaydhakar"
  }
}
